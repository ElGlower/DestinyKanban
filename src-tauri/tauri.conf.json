{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DestinyKanban",
  "version": "1.1.16",
  "identifier": "com.destinykanban.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "DestinyKanban",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGQzI4NzExOEFCRTBFQzgKUldUSURyNktFWWZDajlhTVkrZk5nYkJhbGNmbm1oZUpqVFljSUdhRCtSdlZIQjJodTlrZUgwZTcK",
      "endpoints": [
        "https://raw.githubusercontent.com/ElGlower/DestinyKanban/main/update.json"
      ]
    }
  }
}
